"use client";
import { useState } from "react";
import Image from "next/image"
import { technologies } from "@/components/TechBubble";
import TechDetail from "@/components/TechDetail";
import { motion, AnimatePresence } from "framer-motion";

export default function Home() {

  // react state var
  const [activeTech, setActiveTech] = useState(-1);

  return (
    // Hero Section
    <div className="flex flex-col flex-1 items-center justify-start font-sans text-center">
      <main className="flex flex-col items-center pt-10 w-13/20">
        <h1 className="text-7xl mb-3 font-semibold bg-linear-to-r from-primary to-accent bg-clip-text text-transparent">
          Hello World!
        </h1>
        <div className="mt-3 max-w-md rounded-3xl py-0.5 px-0.5 bg-linear-to-br from-primary to-accent">
          <div className="rounded-[calc(1.5rem-1px)] bg-white p-3">
            <p className="">
              This is my website built with React + Tailwind + NextJS.
            </p>
          </div>
        </div>

        <p className="opacity-0">10/12/02: They watch me... at school, at work, at home.</p>

        <p className="">I feel like something should go here but I&apos;m not sure what. Besides that, this is my own personal website for whatever I please. </p>

        <p className="opacity-0">07/23/01: It was Joseph&apos;s funeral today. I went but I wasn&apos;t there. His mother wasn&apos;t there. Just like me...</p>
        <p className="opacity-0 text-primary">This is where you&apos;re meant to be. Please, don&apos;t leave me again...</p>

        <h1 className="font-bold text-3xl text-center bg-linear-to-r from-primary to-accent bg-clip-text text-transparent">
          Technologies Unlocked!
        </h1>

        {/* Information on left, tech buttons on right */}
        <div className="flex flex-row gap-8 w-full">
          {/* LEFT - Information/Details Display */}
          <section className="w-13/20 py-8">
            <AnimatePresence mode="wait">
              {activeTech !== -1 ? (
                <TechDetail 
                  key={activeTech}
                  tech={technologies[activeTech]} 
                  onClose={() => setActiveTech(-1)} 
                />
              ) : (
                <motion.div
                  key="empty"
                  initial={{ opacity: 0 }}
                  animate={{ opacity: 1 }}
                  exit={{ opacity: 0 }}
                  className="h-full flex items-center justify-center text-text bg-white/3 backdrop-blur-2xl rounded-3xl border border-white/10"
                >
                  <p className="text-center max-w-md p-6">
                    Click on a technology to see its full details and showcase it in all glory! ✨
                  </p>
                </motion.div>
              )}
            </AnimatePresence>
          </section>

          {/* RIGHT - Tech Icon Bubbles */}
          <section className="w-7/20 py-8 flex flex-col items-start justify-start ml-5">
            <div className="flex flex-col space-y-4">
              {technologies.map((tech, index) => (
                <button
                  key={tech.id}
                  onClick={() => setActiveTech(index)}
                  className={`mt-2.5 mb-2.5 relative w-24 h-24 rounded-full overflow-hidden transition-all duration-300 flex items-center justify-center ${
                    index === activeTech
                      ? 'ring-4 ring-primary shadow-lg scale-110'
                      : 'ring-2 ring-gray-300 hover:ring-primary hover:shadow-md'
                  }`}
                >
                  <Image
                    src={tech.icon}
                    alt={tech.name}
                    sizes="96px"
                    fill
                    className="object-contain p-2"
                  />
                </button>
              ))}
            </div>
          </section>
        </div>
      </main>
    </div>
  );
}


